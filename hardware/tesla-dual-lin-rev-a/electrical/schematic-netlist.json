                "EN",
                "BOOT_GPIO0",
                "LIN_A",
                "LIN_B",
                "LIN_A_TJA",
                "LIN_B_TJA",
                "LIN_EN",
                "LIN_EN_DRIVE",
                "ARM_SENSE",
                "WAKE_A_N",
                "WAKE_B_N",
                "INH_A_TP",
                "INH_B_TP",
                "BUCK_PGOOD"
