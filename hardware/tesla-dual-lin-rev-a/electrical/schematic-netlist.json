                "2": "BUCK_FB"
            }
        },
        "R_FB_BOT1": {
            "mpn": "100k 1%",
            "role": "LM5164 feedback low-side resistor for 1.2V reference target near 3.3V",
            "connections": {
                "1": "BUCK_FB",
                "2": "GND"
            }
        },
        "R_BUCK_EN1": {
            "mpn": "100k 1%",
