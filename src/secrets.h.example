// WiFi network XIAO connects to (phone hotspot or shop WiFi)
#define WIFI_SSID       "your-network-name"
#define WIFI_PASS       "your-wifi-password"

// Secretary API base URL (no trailing slash)
// LAN (at shop):       http://192.168.50.77:8002
// Off-LAN (hotspot):   https://ai.abletelsolutions.com
#define SECRETARY_URL   "http://192.168.50.77:8002"

// Vehicle identifier for tagging events (e.g. "tesla-model-x-moti", "tesla-model-3-test")
#define VEHICLE_ID      "tesla-bench"

